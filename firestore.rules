rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /visitors/{visitorId} {
      allow read, write: if true;
    }
    match /stats/{docId} {
      allow read, write: if true;
    }
    match /telemetry_logs/{logId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
  }
}
